<aside class="sidebar" id="sidebar" aria-label="Field guide">
  <div class="sidebar__rail desktop-only">
    <button
      class="sidebar__rail-toggle"
      type="button"
      onclick="toggleSidebar()"
      aria-label="Toggle field guide"
      aria-controls="sidebar"
    >
      ☰
    </button>

    <div class="sidebar__rail-label">Field Guide</div>
  </div>

  <div class="sidebar__panel">
    <div class="sidebar__inner">
      <div class="sidebar__head">
        <div>
          <div class="sidebar__title">Field Guide</div>
          <p class="sidebar__intro">Browse the notebook by pillar, guide, and topic trail.</p>
        </div>

        <button
          class="sidebar__close icon-button"
          type="button"
          onclick="closeSidebar()"
          aria-label="Close field guide"
        >
          ✕
        </button>
      </div>

      <nav class="sidebar-nav">
        {% if navigation and navigation.sections and navigation.sections.length %}
          {% for group in navigation.sections %}
          <section class="sidebar-section open">
            <button
              class="sidebar-section-toggle"
              type="button"
              onclick="toggleSection(this)"
              aria-expanded="true"
            >
              <span class="section-title">
                {% if group.icon %}
                  <span class="section-icon">{{ group.icon }}</span>
                {% endif %}
                {{ group.title }}
              </span>
              <span class="arrow">›</span>
            </button>

            <div class="sidebar-list-wrap">
              <ul class="sidebar-list">
                {% for item in group.items %}
                <li>
                  <a
                    href="{{ item.url }}"
                    {% if page.url == item.url %}aria-current="page"{% endif %}
                  >
                    {{ item.title }}
                  </a>
                </li>
                {% endfor %}
              </ul>
            </div>
          </section>
          {% endfor %}
        {% else %}
          <section class="sidebar-section open">
            <button class="sidebar-section-toggle" type="button" onclick="toggleSection(this)" aria-expanded="true">
              <span class="section-title"><span class="section-icon">✦</span> Start Here</span>
              <span class="arrow">›</span>
            </button>
            <div class="sidebar-list-wrap">
              <ul class="sidebar-list">
                <li><a href="/start-here/" {% if page.url == '/start-here/' %}aria-current="page"{% endif %}>Overview</a></li>
              </ul>
            </div>
          </section>

          <section class="sidebar-section open">
            <button class="sidebar-section-toggle" type="button" onclick="toggleSection(this)" aria-expanded="true">
              <span class="section-title"><span class="section-icon">◎</span> Unschooling Basics</span>
              <span class="arrow">›</span>
            </button>
            <div class="sidebar-list-wrap">
              <ul class="sidebar-list">
                <li><a href="/unschooling/" {% if page.url == '/unschooling/' %}aria-current="page"{% endif %}>Overview</a></li>
              </ul>
            </div>
          </section>

          <section class="sidebar-section open">
            <button class="sidebar-section-toggle" type="button" onclick="toggleSection(this)" aria-expanded="true">
              <span class="section-title"><span class="section-icon">✎</span> Deschooling Lab</span>
              <span class="arrow">›</span>
            </button>
            <div class="sidebar-list-wrap">
              <ul class="sidebar-list">
                <li><a href="/lab/" {% if page.url == '/lab/' %}aria-current="page"{% endif %}>Overview</a></li>
              </ul>
            </div>
          </section>

          <section class="sidebar-section open">
            <button class="sidebar-section-toggle" type="button" onclick="toggleSection(this)" aria-expanded="true">
              <span class="section-title"><span class="section-icon">☁</span> Stories</span>
              <span class="arrow">›</span>
            </button>
            <div class="sidebar-list-wrap">
              <ul class="sidebar-list">
                <li><a href="/stories/" {% if page.url == '/stories/' %}aria-current="page"{% endif %}>Overview</a></li>
              </ul>
            </div>
          </section>

          <section class="sidebar-section open">
            <button class="sidebar-section-toggle" type="button" onclick="toggleSection(this)" aria-expanded="true">
              <span class="section-title"><span class="section-icon">└</span> Rabbit Holes</span>
              <span class="arrow">›</span>
            </button>
            <div class="sidebar-list-wrap">
              <ul class="sidebar-list">
                <li><a href="/rabbit-holes/" {% if page.url == '/rabbit-holes/' %}aria-current="page"{% endif %}>Overview</a></li>
              </ul>
            </div>
          </section>

          <section class="sidebar-section open">
            <button class="sidebar-section-toggle" type="button" onclick="toggleSection(this)" aria-expanded="true">
              <span class="section-title"><span class="section-icon">▣</span> Books</span>
              <span class="arrow">›</span>
            </button>
            <div class="sidebar-list-wrap">
              <ul class="sidebar-list">
                <li><a href="/books/" {% if page.url == '/books/' %}aria-current="page"{% endif %}>Overview</a></li>
              </ul>
            </div>
          </section>

          <section class="sidebar-section open">
            <button class="sidebar-section-toggle" type="button" onclick="toggleSection(this)" aria-expanded="true">
              <span class="section-title"><span class="section-icon">♥</span> Unschooling PTA</span>
              <span class="arrow">›</span>
            </button>
            <div class="sidebar-list-wrap">
              <ul class="sidebar-list">
                <li><a href="/unschooling-pta/" {% if page.url == '/unschooling-pta/' %}aria-current="page"{% endif %}>Overview</a></li>
              </ul>
            </div>
          </section>
        {% endif %}
      </nav>
    </div>
  </div>
</aside>