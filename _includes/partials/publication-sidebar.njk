<div class="sidebar-overlay" data-sidebar-overlay hidden></div>
<aside id="publication-sidebar" class="publication-sidebar" aria-label="Section navigation" data-sidebar>
  <div class="sidebar-brand">
    <a href="/" class="sidebar-brand__title">{{ site.name }}</a>
    <p class="sidebar-brand__meta">Notebook-style publication shell</p>
  </div>

  <a class="sidebar-cta" href="/start-here/">New here? Start here</a>

  <nav class="sidebar-nav">
    {% for group in navigation %}
      {% set items = collections.posts | whereSection(group.key) %}
      {% include "partials/sidebar-section.njk" %}
    {% endfor %}
  </nav>

  <div class="sidebar-footer">
    <p class="sidebar-footnote">Browse by topic</p>
    <a href="/topics/">Auto-generated topic hubs</a>
  </div>
</aside>
