<header class="article-header">
  <div class="article-header__meta">
    <a class="chip" href="/{{ section }}/">{{ section | readableSection }}</a>
    {% if format %}<span class="chip chip--soft">{{ format }}</span>{% endif %}
    {% if access %}<span class="chip chip--soft">{{ access }}</span>{% endif %}
  </div>
  <h1>{{ title }}</h1>
  <p class="article-dek">{{ description }}</p>
</header>
