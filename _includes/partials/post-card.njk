<article class="post-card{% if featured %} post-card--featured{% endif %}">
  <div class="post-card__meta">
    <span class="chip">{{ post.data.section | readableSection }}</span>
    {% set topic = post.data.tags | primaryTopic %}
    {% if topic %}<span class="chip chip--soft">{{ topic | readableSection }}</span>{% endif %}
  </div>
  <h3><a href="{{ post.url }}">{{ post.data.title }}</a></h3>
  <p>{{ post.data.description or post.data.excerpt }}</p>
  <a class="text-link" href="{{ post.url }}">Read entry</a>
</article>
