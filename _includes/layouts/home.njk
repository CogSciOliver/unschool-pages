---
layout: layouts/base.njk
---
<div class="browse-layout">
  <section class="hero-panel notebook-panel">
    <div class="eyebrow">A living notebook for unschooling families</div>
    <h1>{{ title }}</h1>
    <p class="lede">{{ description }}</p>
    <div class="hero-actions">
      <a class="button" href="/start-here/">Start Here</a>
      <a class="button button--secondary" href="/topics/">Browse Topics</a>
    </div>
  </section>

  <section class="browse-grid">
    <article class="panel panel--feature notebook-panel">
      <div class="stamp">Featured Notebook Entry</div>
      <h2>Begin with the path that lowers fear and raises clarity.</h2>
      <p>Use the field guide to move between the basics, deschooling, entertaining stories, rabbit holes, books, and community.</p>
    </article>

    <aside class="panel notebook-panel">
      <div class="stamp">Choose Your Path</div>
      <ul class="path-list">
        {% for item in navigation %}
        <li><a href="{{ item.url }}"><span>{{ item.icon }}</span>{{ item.title }}</a></li>
        {% endfor %}
      </ul>
    </aside>
  </section>

  <section class="section-block">
    <div class="section-heading">
      <div class="stamp">Recent Stories</div>
      <h2>Fresh from the notebook</h2>
    </div>
    <div class="card-grid">
      {% for post in collections.published | reverse %}
      {% if loop.index <= 6 %}
        <article class="post-card notebook-panel">
          <div class="line-space-reset"></div>
        <div class="card-meta">{{ post.data.section | replace("-", " ") | title }}</div>
        <h3><a href="{{ post.url }}">{{ post.data.title }}</a></h3>
        <p>{{ post.data.description }}</p>
        </article>
        {% endif %}
        {% endfor %}
    </div>
  </section>
</div>