---
layout: layouts/page-shell.njk
---
<section class="page-wrap home-page">
  <div class="hero-panel">
    <p class="eyebrow">A living notebook for unschooling families</p>
    <h1>{{ title }}</h1>
    <p class="hero-copy">{{ description }}</p>
    <div class="hero-actions">
      <a class="button button-primary" href="/start-here/">Start Here</a>
      <a class="button button-secondary" href="/community/">Join the Community</a>
    </div>
  </div>

  <section class="section-block">
    <div class="section-heading-row">
      <div>
        <p class="eyebrow">Featured entry</p>
        <h2>Begin with a strong first step</h2>
      </div>
    </div>
    {% set featuredPost = collections.featuredPosts[0] %}
    {% if featuredPost %}
      {% set post = featuredPost %}
      {% set featured = true %}
      {% include "partials/post-card.njk" %}
    {% endif %}
  </section>

  <section class="section-block">
    <div class="section-heading-row">
      <div>
        <p class="eyebrow">Choose your path</p>
        <h2>Browse by pillar</h2>
      </div>
    </div>
    <div class="card-grid card-grid--3">
      {% for group in navigation %}
      <article class="path-card">
        <div class="path-icon">{{ group.icon }}</div>
        <h3><a href="/{{ group.key }}/">{{ group.title }}</a></h3>
        <p>{{ group.description }}</p>
      </article>
      {% endfor %}
    </div>
  </section>

  <section class="section-block">
    <div class="section-heading-row">
      <div>
        <p class="eyebrow">Recent entries</p>
        <h2>Latest from the notebook</h2>
      </div>
      <a class="text-link" href="/topics/">Browse all topics</a>
    </div>
    {% set posts = collections.posts | reverse %}
    {% set limit = 6 %}
    {% include "partials/card-grid.njk" %}
  </section>
</section>
