<!doctype html>
<html lang="en" data-theme="light">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{% if title %}{{ title }} | {% endif %}{{ site.title }}</title>
  <meta name="description" content="{{ description or site.description }}">
  <link rel="canonical" href="{{ site.url }}{{ page.url }}">
  <meta property="og:title" content="{% if title %}{{ title }} | {% endif %}{{ site.title }}">
  <meta property="og:description" content="{{ description or site.description }}">
  <meta property="og:url" content="{{ site.url }}{{ page.url }}">
  <meta property="og:type" content="website">
  <link rel="stylesheet" href="/assets/css/tokens.css">
  <link rel="stylesheet" href="/assets/css/shell.css">
  <link rel="stylesheet" href="/assets/css/components.css">
  <link rel="stylesheet" href="/assets/css/notebook.css">
  <script>
    const savedTheme = localStorage.getItem('theme');
    if (savedTheme) document.documentElement.setAttribute('data-theme', savedTheme);
  </script>
</head>
<body>
  {% include "partials/header.njk" %}

  <button class="rail-toggle desktop-only" type="button" aria-label="Open field guide" aria-controls="sidebar" aria-expanded="false" onclick="toggleSidebar(true)">
    <span class="rail-toggle__icon">☰</span>
    <span class="rail-toggle__label">Field Guide</span>
  </button>

  <div class="scrim" id="sidebar-scrim" hidden onclick="closeSidebar()"></div>
  <div class="scrim" id="menu-scrim" hidden onclick="closeTopMenu()"></div>

  {% include "partials/sidebar.njk" %}

  <div class="shell">
    <main class="page-main" id="page-main">
      {{ content | safe }}
    </main>
  </div>

  {% include "partials/footer.njk" %}
  <script src="/assets/js/sidebar.js"></script>
</body>
</html>
