---
pagination:
  data: collections.topicHubs
  size: 1
  alias: hub
permalink: "/topics/{{ hub.slug }}/"
layout: layouts/base.njk
---
<section class="section-hero notebook-panel">
  <div class="stamp">Topic Hub</div>
  <h1>{{ hub.slug | title }}</h1>
  <p class="lede">Stories connected by the theme of {{ hub.slug }}.</p>
</section>
<section class="section-block">
  <div class="card-grid">
    {% for post in hub.items %}
    <article class="post-card notebook-panel">
      <div class="card-meta">{{ post.data.section | title }}</div>
      <h3><a href="{{ post.url }}">{{ post.data.title }}</a></h3>
      <p>{{ post.data.description }}</p>
    </article>
    {% endfor %}
  </div>
</section>
