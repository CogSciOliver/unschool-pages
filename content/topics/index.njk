
---
layout: layouts/page-shell.njk
title: Topic Hubs
description: Browse the publication by recurring themes and interest clusters.
permalink: /topics/
---
<section class="page-wrap">
  <section class="hero-panel hero-panel--section">
    <p class="eyebrow">Topic hubs</p>
    <h1>{{ title }}</h1>
    <p class="hero-copy">{{ description }}</p>
  </section>

  <section class="section-block">
    <div class="card-grid card-grid--3">
      {% for topic in collections.topicHubs %}
      <article class="path-card">
        <p class="eyebrow">{{ topic.count }} entries</p>
        <h3><a href="/topics/{{ topic.slug }}/">{{ topic.title }}</a></h3>
        <p>Auto-generated from post tags so your archive stays discoverable without manual hub maintenance.</p>
      </article>
      {% endfor %}
    </div>
  </section>
</section>
