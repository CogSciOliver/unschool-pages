---
layout: layouts/page-shell.njk
pagination:
  data: collections.topicHubs
  size: 1
  alias: topic
permalink: "/topics/{{ topic.slug }}/index.html"
eleventyComputed:
  title: "{{ topic.title }}"
  description: "Browse all entries tagged with {{ topic.title }}."
---
<section class="page-wrap">
  <section class="hero-panel hero-panel--section">
    <p class="eyebrow">Topic hub</p>
    <h1>{{ topic.title }}</h1>
    <p class="hero-copy">{{ topic.count }} entries grouped automatically by shared tags.</p>
  </section>

  <section class="section-block">
    {% set posts = collections.postsByTopic.get(topic.slug) %}
    {% include "partials/card-grid.njk" %}
  </section>
</section>
